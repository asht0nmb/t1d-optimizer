# Public (embedded in client bundle — anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transaction pooler URL for Postgres aggregations (heatmap, TIR, search)
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Calendar-day boundaries for day view and SQL aggregations
TZ=America/Los_Angeles

# Optional: filter all queries to one pump
DEFAULT_PUMP_SERIAL=

# Clinical report worker (the repo-root Vercel Python project).
# The /api/report route proxies to METRICS_WORKER_URL/api/metrics_report,
# authenticating with CRON_SECRET (reused below).
METRICS_WORKER_URL=https://YOUR_WORKER_PROJECT.vercel.app

# Meal-rise cron (Vercel Cron → /api/meal_rise_cron Python handler).
# CRON_SECRET is also the bearer secret the /api/report proxy sends to the
# metrics worker — it must match the worker project's CRON_SECRET.
CRON_SECRET=
DEXCOM_USERNAME=
DEXCOM_PASSWORD=
DEXCOM_OUS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: override BG targets JSON (otherwise apps/web/config/bg-targets.json)
# USER_CONFIG_PATH=/path/to/user_config.json
