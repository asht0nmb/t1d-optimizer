# Public (embedded in client bundle — anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transaction pooler URL for Postgres aggregations (heatmap, TIR, search)
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Calendar-day boundaries for day view and SQL aggregations
TZ=America/Los_Angeles

# Optional: filter all queries to one pump
DEFAULT_PUMP_SERIAL=

# Optional: override BG targets JSON (otherwise apps/web/config/bg-targets.json)
# USER_CONFIG_PATH=/path/to/user_config.json
