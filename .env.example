# Tandem t:connect credentials (used by ingestion/client.py for OIDC login)
TCONNECT_EMAIL=you@example.com
TCONNECT_PASSWORD=your-password

# Local timezone for ingestion / display (IANA name; e.g. America/Los_Angeles)
TIMEZONE_NAME=America/Los_Angeles

# Supabase Postgres direct connection URL (for the one-time bootstrap and
# future writes). Use the DIRECT connection (port 5432, host
# db.<project-ref>.supabase.co), NOT the pooler — the pooler has statement
# size limits and prepared-statement constraints that bulk inserts will hit.
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres
TIMEZONE_NAME='America/Los_Angeles'  # could place in a config (not important)
DEXCOM_USERNAME='xyz@gmail.com'
DEXCOM_PASSWORD='xyz'
DEXCOM_OUS=false4
TELEGRAM_BOT_TOKEN='abc123'
TELEGRAM_CHAT_ID='123'
NEXT_PUBLIC_SUPABASE_URL='xyz'
NEXT_PUBLIC_SUPABASE_ANON_KEY='xyz'
SUPABASE_SERVICE_ROLE_KEY='xyz'
CRON_SECRET='123'
VERCEL_APP_URL='xyz.com'